# OpenAI-compatible endpoint used by the construction and evaluation clients.
# Never commit real credentials.
WSB_API_BASE=https://your-provider.example/v1
WSB_API_KEY=replace-with-your-key

# Optional model used by LLM-assisted data construction.
WSB_BUILD_MODEL=gpt-4o-mini

# Optional per-provider keys used by legacy multi-model audit scripts.
WSB_GPT_KEY=replace-with-your-key
WSB_CLAUDE_KEY=replace-with-your-key
WSB_GEMINI_KEY=replace-with-your-key
