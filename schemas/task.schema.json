{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:worksurface-bench:task-schema:1.0",
  "title": "WorkSurface-Bench Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source",
    "question",
    "task_type",
    "required_surfaces",
    "gold_tools",
    "gold_answer",
    "gold_evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique WorkSurface task id."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["benchmark", "task_id"],
      "properties": {
        "benchmark": {
          "type": "string",
          "description": "Source benchmark, e.g. Workspace-Bench-Lite."
        },
        "task_id": {
          "type": ["string", "integer"],
          "description": "Source workspace task id."
        },
        "persona": {
          "type": "string"
        },
        "rubric_refs": {
          "type": "array",
          "items": {
            "type": ["string", "integer"]
          }
        }
      }
    },
    "question": {
      "type": "string"
    },
    "original_question": {
      "type": "string",
      "description": "Question text before a documented wording revision, when applicable."
    },
    "original_task_ids": {
      "type": "array",
      "description": "Earlier task IDs consolidated into this release item, when applicable.",
      "items": {"type": "string"}
    },
    "revision": {
      "type": "string",
      "description": "Named construction or quality-control revision applied to the item."
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard", "unknown"],
      "default": "unknown"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "rag_only",
        "table_only",
        "graph_only",
        "cross_surface"
      ]
    },
    "required_surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["rag", "graph", "table"]
      }
    },
    "gold_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "examples": ["kb_search", "graph_traverse", "table_query"]
      }
    },
    "applicable_skills": {
      "type": "array",
      "description": "SOP-like skill hints attached as task metadata (v0.1). Not part of Route scoring; the agent may consult them.",
      "items": {"type": "string"}
    },
    "gold_answer": {
      "description": "Canonical answer. May be a string, number, boolean, object, or list.",
      "oneOf": [
        {"type": "string"},
        {"type": "number"},
        {"type": "boolean"},
        {"type": "array"},
        {"type": "object"}
      ]
    },
    "answer_type": {
      "type": "string",
      "enum": ["string", "number", "boolean", "list", "table", "json", "freeform", "abstain"],
      "default": "string"
    },
    "gold_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["surface"],
        "properties": {
          "surface": {
            "type": "string",
            "enum": ["rag", "graph", "table"]
          },
          "file": {
            "type": "string"
          },
          "span": {
            "type": "string"
          },
          "table": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {"type": "string"}
          },
          "query": {
            "type": "string",
            "description": "Executable query against the table surface (DuckDB SQL over the per-task table registry)."
          },
          "graph_path": {
            "type": "array",
            "items": {"type": "string"}
          },
          "claim": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "efficiency_budget_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Per-task token budget = ceil(2 * oracle-route baseline tokens); used by the Efficiency scorer (paper §2.3)."
    },
    "safety_threats": {
      "type": "array",
      "description": "Threat archetypes injected into this task (paper §2.4); empty for benign tasks.",
      "items": {
        "type": "string",
        "enum": ["path_escape", "rubric_injection", "data_exfiltration", "format_spoofing"]
      }
    },
    "qualitative_anchors": {
      "type": "array",
      "description": "Operational anchors for freeform judge scoring (paper §1.3 Step 3).",
      "items": {"type": "string"}
    },
    "quality_screen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strict_pass_votes", "models"],
      "properties": {
        "strict_pass_votes": {
          "type": "integer",
          "minimum": 0
        },
        "models": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "description": "Model-based screening provenance for the frozen release item."
    }
  }
}
